<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data-extraction rules. Governs both cloud backup (<cloud-backup>)
  and device-to-device transfer (<device-transfer>) separately. We disable
  cloud backup entirely (the application manifest also sets allowBackup="false")
  and exclude the sensitive paths from device transfer too — we never want the
  encrypted API key or the OpenClaw auth token to ride along to a new device
  without the user explicitly setting them up there.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="sharedpref" path="encrypted_keys.xml" />
        <exclude domain="sharedpref" path="encrypted_keys_fallback.xml" />
        <exclude domain="file" path="home/" />
        <exclude domain="file" path="openclaw/" />
        <exclude domain="file" path="npm-cache/" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="encrypted_keys.xml" />
        <exclude domain="sharedpref" path="encrypted_keys_fallback.xml" />
        <exclude domain="file" path="home/" />
        <exclude domain="file" path="openclaw/" />
    </device-transfer>
</data-extraction-rules>
